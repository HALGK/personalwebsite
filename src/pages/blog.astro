---
import BaseLayout from '../layouts/BaseLayout.astro';
import { blogConfig, siteConfig } from '../config';
---

<BaseLayout title="Blog" description="Writing and reflections by Hermann Lücken genannt Klaßen on energy policy, European politics, and academic life.">
  <div class="mb-10">
    <h1 class="font-serif text-3xl font-semibold text-stone-900 mb-2">Blog</h1>
    <p class="text-stone-500">Writing on energy policy, European politics & academic life</p>
  </div>

  {!blogConfig.substackUrl ? (
    <!-- Placeholder wenn Substack noch nicht eingerichtet -->
    <div class="bg-stone-100 border border-dashed border-stone-300 rounded-xl p-10 text-center">
      <p class="text-4xl mb-4">✍️</p>
      <h2 class="font-serif text-xl font-semibold text-stone-700 mb-2">Coming Soon</h2>
      <p class="text-stone-500 mb-6">I'm setting up my blog. Check back soon, or subscribe to get notified when new posts go live.</p>
      <p class="text-stone-400 text-sm">The blog will be powered by Substack.</p>
    </div>
  ) : (
    <div class="space-y-8">
      <!-- Substack Embed -->
      <div class="bg-white border border-stone-200 rounded-xl p-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-2xl">📬</span>
          <div>
            <p class="font-semibold text-stone-800">Subscribe on Substack</p>
            <p class="text-stone-500 text-sm">Get new posts directly in your inbox</p>
          </div>
        </div>
        <a
          href={blogConfig.substackUrl}
          target="_blank"
          class="inline-block px-5 py-2 bg-orange-500 text-white rounded hover:bg-orange-600 transition-colors text-sm font-medium"
        >
          Subscribe on Substack →
        </a>
      </div>
      <!-- Recent Posts via RSS (static fallback) -->
      <div class="bg-amber-50 border border-amber-100 rounded-lg p-4 text-sm text-amber-700">
        <p>💡 <strong>Tip:</strong> To display your latest Substack posts automatically, you can configure a Netlify function to fetch from your RSS feed. Ask me and I'll set it up!</p>
      </div>
    </div>
  )}
</BaseLayout>
